{
  "_comment_": "Full 10M-reservoir config — curated parameter set per layer (only knobs that visually change the reservoir). Channels & delta drive the new Alluvsim-faithful fluvial engine. Channels mix the 5 Pyrcz-2004 presets via the 'preset' field; user-supplied params override preset defaults.",
  "output_dir": "/pscratch/sd/i/ilgar/georules_dataset",
  "seed": 42,
  "shard_size": 10000,
  "grid": {
    "nx": 64, "ny": 64, "nz": 32,
    "x_len": 5000.0, "y_len": 5000.0, "z_len": 30.0,
    "top_depth": 2000.0, "dip": 0.0, "kzkx": 0.1
  },
  "layers": {
    "lobe": {
      "count": 2500000,
      "sampling": "sobol",
      "params": {
        "poro_ave":     {"range": [0.15, 0.35]},
        "perm_ave":     {"range": [0, 4]},
        "poro_std":     {"range": [0.01, 0.05]},
        "perm_std":     {"range": [0.1, 1.5]},
        "ntg":          {"range": [0.2, 0.8]},
        "dhmin":        {"range": [2, 5],     "type": "int"},
        "dhmax":        {"range": [6, 10],    "type": "int"},
        "rmin":         {"range": [20, 45]},
        "rmax":         {"range": [50, 80]},
        "asp":          {"range": [1.0, 2.5]},
        "bouma_factor": {"range": [0, 2]},
        "m":            {"value": 100},
        "upthinning":   {"choices": [true, false]}
      }
    },
    "gaussian": {
      "count": 1000000,
      "sampling": "sobol",
      "params": {
        "poro_ave":       {"range": [0.15, 0.35]},
        "perm_ave":       {"range": [0, 4]},
        "poro_std":       {"range": [0.01, 0.05]},
        "perm_std":       {"range": [0.1, 1.5]},
        "ntg":            {"range": [0.2, 0.8]},
        "nugget":         {"range": [0.01, 0.15]},
        "poro_perm_corr": {"range": [0.3, 0.9]}
      }
    },
    "meandering": {
      "count": 2500000,
      "sampling": "sobol",
      "params": {
        "preset":          {"choices": ["PV_SHOESTRING", "CB_LABYRINTH", "SH_DISTAL", "SH_PROXIMAL"]},
        "mCHsinu":         {"range": [1.15, 1.75]},
        "mCHwdratio":      {"range": [8.0, 22.0]},
        "mCHdepth":        {"range": [2.0, 5.0]},
        "probAvulInside":  {"range": [0.02, 0.4]},
        "mFFCHprop":       {"range": [0.0, 0.5]},
        "mdistMigrate":    {"range": [15.0, 40.0]},
        "NTGtarget":       {"range": [0.10, 0.50]},
        "azimuth":         {"range": [0, 360]}
      }
    },
    "braided": {
      "count": 2500000,
      "sampling": "sobol",
      "params": {
        "preset":          {"value": "CB_JIGSAW"},
        "mCHsinu":         {"range": [1.10, 1.40]},
        "mCHwdratio":      {"range": [12.0, 22.0]},
        "mCHdepth":        {"range": [2.5, 4.0]},
        "probAvulInside":  {"range": [0.20, 0.55]},
        "mFFCHprop":       {"range": [0.2, 0.7]},
        "NTGtarget":       {"range": [0.20, 0.45]},
        "azimuth":         {"range": [0, 360]}
      }
    },
    "delta": {
      "count": 1500000,
      "sampling": "sobol",
      "params": {
        "trunk_length_fraction": {"range": [0.2, 0.6]},
        "progradation_fraction": {"range": [0.0, 0.5]},
        "branch_spread_deg":     {"range": [0.0, 45.0]},
        "n_generations":         {"range": [4, 12], "type": "int"},
        "ntime_per_gen":         {"range": [40, 120], "type": "int"},
        "mCHsinu":               {"range": [1.05, 1.30]},
        "mFFCHprop":             {"range": [0.0, 0.4]},
        "paint_mouth_bars":      {"choices": [true, false]},
        "azimuth":               {"range": [0, 360]}
      }
    }
  }
}

{
  "_comment_": "Full 10M-reservoir config \u2014 curated parameter set per layer (only knobs that visually change the reservoir). Channels & delta drive the new Alluvsim-faithful fluvial engine. Channels mix the 5 Pyrcz-2004 presets via the 'preset' field; user-supplied params override preset defaults.",
  "output_dir": "$SCRATCH/resmill_dataset/lobes",
  "seed": 42,
  "shard_size": 1000,
  "grid": {
    "nx": 80,
    "ny": 80,
    "nz": 50,
    "x_len": 8000.0,
    "y_len": 8000.0,
    "z_len": 50.0,
    "top_depth": 5000.0,
    "dip": 0.0,
    "kzkx": 0.1,
    "crop": {
      "x": "8:-8",
      "y": "8:-8",
      "z": "9:-9"
    }
  },
  "layers": {
    "lobe": {
      "count": 200000,
      "sampling": "sobol",
      "params": {
        "poro_ave": {
          "range": [
            0.1,
            0.3
          ]
        },
        "perm_ave": {
          "range": [
            1,
            3
          ]
        },
        "poro_std": {
          "value": 0.03
        },
        "perm_std": {
          "value": 0.2
        },
        "ntg": {
          "range": [
            0.15,
            0.9
          ]
        },
        "dh_ave": {
          "range": [
            5,
            20
          ],
          "shared": "size",
          "jitter": 0.5
        },
        "dh_std": {
          "value": 0.2,
          "fraction_of": "dh_ave"
        },
        "r_ave": {
          "range": [
            600,
            4000
          ],
          "shared": "size",
          "jitter": 0.5
        },
        "r_std": {
          "value": 0.2,
          "fraction_of": "r_ave"
        },
        "asp": {
          "range": [
            1.0,
            2.5
          ]
        },
        "m": {
          "value": 50
        },
        "azimuth": {
          "range": [
            0,
            360
          ]
        },
        "upthinning": {
          "choices": [
            true,
            false
          ]
        }
      }
    }
  }
}